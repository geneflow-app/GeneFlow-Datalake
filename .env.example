# GeneFlow Datalake Configuration
# Copy to .env and fill in your values

# Redis
DATALAKE_REDIS_URL=redis://localhost:6379
DATALAKE_REDIS_CONSUMER_GROUP=geneflow-datalake-consumers
DATALAKE_REDIS_CONSUMER_NAME=geneflow-datalake-1

# Storage Provider: local, minio, or supabase
DATALAKE_STORAGE_PROVIDER=local

# Local Storage (when STORAGE_PROVIDER=local)
DATALAKE_LOCAL_STORAGE_PATH=./data/datalake

# MinIO / S3-compatible (when STORAGE_PROVIDER=minio)
DATALAKE_MINIO_ENDPOINT=localhost:9000
DATALAKE_MINIO_ACCESS_KEY=
DATALAKE_MINIO_SECRET_KEY=
DATALAKE_MINIO_BUCKET=geneflow-datalake
DATALAKE_MINIO_SECURE=false

# Supabase Storage (when STORAGE_PROVIDER=supabase)
DATALAKE_SUPABASE_URL=https://your-project.supabase.co
DATALAKE_SUPABASE_KEY=
DATALAKE_SUPABASE_BUCKET=geneflow-datalake

# Buffer
DATALAKE_BUFFER_MAX_SIZE=1000
DATALAKE_BUFFER_FLUSH_INTERVAL=5.0
DATALAKE_WAL_PATH=./data/wal

# Retry
DATALAKE_RETRY_MAX_ATTEMPTS=5
DATALAKE_RETRY_BASE_DELAY=1.0
DATALAKE_RETRY_MAX_DELAY=300.0
DATALAKE_DLQ_PATH=./data/dlq

# Deduplication
DATALAKE_DEDUP_TTL_HOURS=24
DATALAKE_DEDUP_MAX_SIZE=100000

# API
DATALAKE_API_HOST=0.0.0.0
DATALAKE_API_PORT=8080
DATALAKE_API_KEY=
